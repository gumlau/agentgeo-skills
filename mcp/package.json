  "author": "AgentGEO <logan@agentgeo.org>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gumlau/agentgeo-skills.git",
    "directory": "mcp"
  },
  "homepage": "https://agentgeo.org",
  "private": false,
  "type": "module",
  "bin": {
    "agentgeo-mcp": "index.mjs"
  },
  "files": [
    "index.mjs",
    "skills.generated.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
